from airflow import DAG
from airflow.operators.python import PythonOperator
from datetime import datetime, timedelta
import pandas as pd
import os

default_args = {
    'owner': 'Sarah_Ityav',
    'start_date': datetime(2026, 4, 1),
    'retries': 1,
}

with DAG(
    dag_id='sarah_retail_dag',
    default_args=default_args,
    schedule_interval='0 8 * * 1', # Mondays at 8:00 AM
    catchup=False
) as dag:

    def extract():
        # Using local paths based on your VS Code explorer
        input_file = 'include/food_prices_raw.csv'
        staging_file = 'include/raw_staging.csv'
        
        if not os.path.exists(input_file):
            raise FileNotFoundError(f"Missing: {input_file}")
            
        df = pd.read_csv(input_file)
        df.to_csv(staging_file, index=False)
        print("Raw data extracted successfully.")

    def transform():
        staging_file = 'include/raw_staging.csv'
        # Final output saved in the include folder as requested
        final_file = 'include/food_prices_cleaned.csv'
        
        df = pd.read_csv(staging_file)
        
        # Transformation Logic
        df['Market'] = df['Market'].str.upper() # [cite: 53]
        df['Price'] = df['Price'].replace(r'[N,\s]', '', regex=True).astype(float) # [cite: 54]
        
        df.to_csv(final_file, index=False)
        print(f"Clean data saved to {final_file}")

    task_1 = PythonOperator(task_id='extract_prices', python_callable=extract)
    task_2 = PythonOperator(task_id='transform_and_clean', python_callable=transform)

    task_1 >> task_2